# Homebrew (must run before antidote, which is brew-installed)
eval "$(/opt/homebrew/bin/brew shellenv)"

# Custom completion functions (e.g. ~/.zfunc/_rustup) — must precede compinit
fpath=(${ZDOTDIR:-$HOME}/.zfunc(N) $fpath)

# antidote plugin manager — loads plugins from ~/.zsh_plugins.txt.
# Zephyr provides the Prezto-equivalent core modules (completion, history, etc.).
source /opt/homebrew/opt/antidote/share/antidote/antidote.zsh
antidote load

# Restore prior Prezto behavior that Zephyr leaves off by default
setopt SHARE_HISTORY   # share command history across sessions
setopt AUTO_CD         # type a directory name to cd into it

# ls family powered by eza (modern ls). Sub-aliases chain onto the base `ls`.
alias ls='eza --group-directories-first --icons=auto'
alias l='ls -1a'                  # one column, include hidden
alias ll='ls -l --git'            # long format, git status
alias la='ls -la --git'           # long format, include hidden
alias lr='ls -l --recurse'        # long format, recursive
alias lk='ls -l --sort=size'      # long format, sorted by size
alias lt='ls -l --sort=modified'  # long format, sorted by time
alias tree='ls --tree'            # tree view
alias sl='ls'                     # common typo

# atuin owns history search (Ctrl-R + ↑). Bind in zvm_after_init because
# zsh-vi-mode resets keymaps on init, which would otherwise clobber these.
function zvm_after_init() {
  bindkey -M viins '^r' atuin-search-viins
  bindkey -M vicmd '^r' atuin-search-vicmd
  bindkey -M viins '^[[A' atuin-up-search-viins
  bindkey -M vicmd '^[[A' atuin-up-search-vicmd
  bindkey -M viins '^[OA' atuin-up-search-viins
  bindkey -M vicmd '^[OA' atuin-up-search-vicmd
}

# Starship prompt (https://starship.rs). Customize via ~/.config/starship.toml
eval "$(starship init zsh)"

# Modern CLI tools
eval "$(zoxide init zsh)"        # `z`/`zi` — smarter cd by frecency
export ATUIN_NOBIND=true         # we bind atuin ourselves (see zvm_after_init)
eval "$(atuin init zsh)"         # searchable SQLite shell history (Ctrl-R + ↑)

# brew jenv
export PATH="$HOME/.jenv/bin:$PATH"
eval "$(jenv init -)"

# brew postgresql@17
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"

. "$HOME/.cargo/env"

# bun completions
[ -s "/Users/ohe/.bun/_bun" ] && source "/Users/ohe/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/ohe/.lmstudio/bin"
# End of LM Studio CLI section

# Scaleway CLI autocomplete initialization.
eval "$(scw autocomplete script shell=zsh)"

# JetBrains Toolbox scripts (migrated from the old prezto ~/.zprofile)
export PATH="$PATH:$HOME/Library/Application Support/JetBrains/Toolbox/scripts"
