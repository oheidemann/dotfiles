source $HOME/.zprezto/runcoms/zshrc

eval $(/opt/homebrew/bin/brew shellenv)

export ZPLUG_HOME=/opt/homebrew/opt/zplug
source $ZPLUG_HOME/init.zsh

# Plugins
zplug "plugins/git",   from:oh-my-zsh
zplug "plugins/osx",   from:oh-my-zsh
zplug "zsh-users/zsh-autosuggestions"
zplug 'ryutok/rust-zsh-completions'
zplug "jeffreytse/zsh-vi-mode"

# Install any declared-but-missing plugins (keeps a fresh machine reproducible)
if ! zplug check; then
  zplug install
fi

zplug load

# Starship prompt (https://starship.rs). Customize via ~/.config/starship.toml
eval "$(starship init zsh)"

# brew jenv
export PATH="$HOME/.jenv/bin:$PATH"
eval "$(jenv init -)"

# brew postgresql@17
export PATH="/opt/homebrew/opt/postgresql@17/bin:$PATH"

. "$HOME/.cargo/env"

# bun completions
[ -s "/Users/ohe/.bun/_bun" ] && source "/Users/ohe/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/ohe/.lmstudio/bin"
# End of LM Studio CLI section

# Scaleway CLI autocomplete initialization.
eval "$(scw autocomplete script shell=zsh)"
